# =====================================================
# 環境変数テンプレート (.env.example)
# =====================================================
# このファイルを .env にコピーして値を設定してください
# GitHub Actions では Secrets として設定します

# ─── 調査 API ───────────────────────────────────────
# Tavily API (Primary): https://tavily.com/
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Brave Search API (Fallback): https://brave.com/search/api/
BRAVE_SEARCH_API_KEY=BSA-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── 台本生成 API ────────────────────────────────────
# Google Gemini API (Primary, 無料枠): https://aistudio.google.com/
GOOGLE_GEMINI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic Claude API (有償 Fallback, 任意): https://console.anthropic.com/
# ※ 設定しない場合は Gemini のみ使用 (完全無料)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Google Drive 認証 ──────────────────────────────
# setup/setup_google_auth.py を Google Colab で実行して取得
GOOGLE_DRIVE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_DRIVE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_DRIVE_REFRESH_TOKEN=1//xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
